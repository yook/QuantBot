{
  "name": "pageviewer",
  "productName": "PageViewer",
  "description": "PageViewer — инструмент для краулинга и анализа сайтов",
  "author": "Yook",
  "private": true,
  "version": "1.3.2",
  "type": "module",
  "scripts": {
    "test": "node --loader ts-node/esm ./test/db-migrations.test.mjs",
    "dev": "vite",
    "generate:icons": "node ./build-scripts/generate-icons.js",
    "build": "vue-tsc && vite build && electron-builder",
    "build:win:x64": "vue-tsc && vite build && electron-builder --win --x64",
    "build:win:portable": "vue-tsc && vite build && electron-builder --win portable --x64",
    "build:win": "vue-tsc && vite build && electron-builder --win --x64",
    "build:win:cross": "vue-tsc && vite build && electron-builder --win --x64 --config.extraMetadata.main=dist-electron/main.js",
    "build:win:portable:cross": "vue-tsc && vite build && electron-builder --win portable --x64 --config.extraMetadata.main=dist-electron/main.js",
    "build:win:portable:ci": "vite build && electron-builder --win portable --x64 --config.extraMetadata.main=dist-electron/main.js",
    "preview": "vite preview",
    "electron:dev": "vite --mode electron",
    "electron:restart": "killall Electron || true && npm run electron:dev",
    "electron:prod-test": "node ./scripts/run-prod-test.cjs",
    "update:serve": "node ./scripts/serve-update-feed.js",
    "rebuild:sqlite": "bash ./scripts/rebuild-sqlite.sh",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "bindings": "^1.5.0",
    "cheerio": "^1.1.2",
    "electron-updater": "^6.6.2",
    "element-plus": "^2.12.0",
    "file-uri-to-path": "^2.0.0",
    "jsdom": "^26.0.0",
    "pinia": "^3.0.4",
    "playwright-chromium": "^1.52.0",
    "simplecrawler": "^1.1.9",
    "validator": "^13.15.23",
    "vue": "^3.5.25",
    "vue-i18n": "^11.2.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.68",
    "@iconify-json/tabler": "^1.2.33",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/better-sqlite3": "^7.6.13",
    "@types/validator": "^13.15.10",
    "@vitejs/plugin-vue": "^6.0.2",
    "autoprefixer": "^10.4.22",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "icon-gen": "^5.0.0",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "unplugin-icons": "^22.5.0",
    "unplugin-vue-components": "^0.27.5",
    "vite": "^7.2.7",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^3.1.8"
  },
  "main": "dist-electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/yook/PageViewer"
  }
}
