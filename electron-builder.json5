// @see - https://www.electron.build/configuration/configuration
{
  $schema: "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  appId: "com.yook.pageviewer",
  asar: true,
  productName: "PageViewer",
  directories: {
    output: "release/${version}",
    buildResources: "public",
  },
  icon: "build/icons/pageviewer",
  files: [
    "dist",
    "dist-electron",
    // Include worker entry files explicitly. They are spawned separately and
    // should not rely on auto-discovery inside the bundled app.
    "electron/workers/crawlerWorker.cjs",
    "electron/workers/parserBatchWorker.cjs",
    "electron/workers/parserExtractor.cjs",
    "electron/workers/parserWorker.cjs",
    // Runtime dependency allowlist (instead of shipping full node_modules).
    "node_modules/better-sqlite3/**/*",
    "node_modules/bindings/**/*",
    "node_modules/file-uri-to-path/**/*",
    "node_modules/cheerio/**/*",
    "node_modules/electron-updater/**/*",
    "node_modules/element-plus/**/*",
    "node_modules/jsdom/**/*",
    "node_modules/pinia/**/*",
    "node_modules/playwright-chromium/**/*",
    "node_modules/playwright-core/**/*",
    "node_modules/simplecrawler/**/*",
    "node_modules/validator/**/*",
    "node_modules/vue/**/*",
    "node_modules/vue-i18n/**/*",
    "node_modules/xlsx/**/*",
    // Drop non-runtime baggage from packaged dependencies.
    "!**/{test,tests,__tests__,powered-test,example,examples,docs,doc,coverage}/**",
    "!**/.github/**",
    "!**/*.d.ts",
    "!**/*.map",
    "!**/tsconfig*.json",
    "!**/typedoc*.json",
    "!**/vite.config.*",
    "!**/rollup.config.*",
    "!**/webpack.config.*",
    "!**/eslint.config.*",
    "!**/.eslintrc*",
    "!**/.prettierrc*",
    "!**/CHANGELOG*",
    "!**/README*",
    "!node_modules/better-sqlite3/src/**",
    "!node_modules/jsdom/lib/jsdom/living/xhr/xhr-sync-worker.js.map",
  ],
  // Keep unpacked only what truly needs filesystem access outside ASAR:
  // worker entrypoints plus native modules / helpers used to resolve them.
  asarUnpack: [
    // Native modules and the small helper packages used to locate them.
    "node_modules/**/*.node",
    "node_modules/better-sqlite3/**",
    "node_modules/bindings/**",
    "node_modules/file-uri-to-path/**",
  ],
  mac: {
    target: ["dmg"],
    artifactName: "${productName}-Mac-${version}-Installer.${ext}",
  },
  win: {
    target: [
      {
        target: "nsis",
        arch: ["x64"],
      },
    ],
    artifactName: "${productName}-Windows-${version}-Setup.${ext}",
  },
  nsis: {
    oneClick: false,
    perMachine: false,
    allowToChangeInstallationDirectory: true,
    deleteAppDataOnUninstall: false,
  },
  linux: {
    target: ["AppImage"],
    artifactName: "${productName}-Linux-${version}.${ext}",
  },
  publish: [
    {
      provider: "github",
      owner: "yook",
      repo: "PageViewer",
    },
  ],
}
